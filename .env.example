# Скопируйте в .env и измените значения перед запуском:
#   copy .env.example .env

# Обязательно смените SECRET_KEY в production
SECRET_KEY=change-me-to-a-long-random-string

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Порт на хосте (внутри контейнера всегда 8000)
WEB_PORT=8000

# Для HTTPS за reverse-proxy (через запятую, с протоколом)
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Публичный URL сайта (для sitemap, canonical, юридических документов)
# SITE_URL=https://example.com
# SITE_HOST=example.com

# Email для контактов в юридических документах
# SITE_CONTACT_EMAIL=info@example.com

# Веб-аналитика (скрипты загружаются только после согласия пользователя)
# YANDEX_METRICA_ID=12345678
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Планировщик синхронизации релизов 1С (включите на production-сервере)
# FREESC_RUN_SCHEDULER=True
# FREESC_SYNC_CHECK_INTERVAL_HOURS=6

# IndexNow (опционально)
# INDEXNOW_ENABLED=True
# INDEXNOW_KEY=your-indexnow-key

# --- CI/CD (GitHub Actions secrets, не в .env) ---
# SSH_HOST, SSH_USER, SSH_PRIVATE_KEY, DEPLOY_PATH, SSH_PORT
# Инструкция: см. DEPLOY.md
